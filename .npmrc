# Enforce the engines field from package.json. The preinstall
# script in package.json is a second line of defense — together
# they make `npm install` fail loudly with a clear message
# pointing the user at `bun install`.
engine-strict=true

# Save exact versions on `bun add` so the lockfile stays
# reproducible across machines.
save-exact=true

# Don't generate a package-lock.json — we use bun.lock and
# the rest of the toolchain (Vite, Biome, etc.) already
# prefers it when present.
package-lock=false
