{
	"name": "seba3567.cl",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"bun": ">=1.3.0",
		"node": ">=20.0.0"
	},
	"packageManager": "bun@1.3.14",
	"scripts": {
		"dev": "vite dev",
		"predev": "bun run optimize:images && bun run generate:og && bun run sync:aosp",
		"prebuild": "bun run optimize:images && bun run generate:og && bun run sync:aosp",
		"preinstall": "node -e \"if(!process.env.npm_config_user_agent?.startsWith('bun')){console.error('ERROR: This project uses Bun. Run: bun install');process.exit(1)}\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsgo --tsconfig ./tsconfig.json && bun run lint:check && bun run test:run",
		"check:watch": "svelte-kit sync && svelte-check --tsgo --tsconfig ./tsconfig.json --watch",
		"tsgo": "tsgo",
		"check-types": "tsgo --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:ui": "vitest --ui",
		"lhci": "lhci autorun",
		"lint": "biome check .",
		"lint:check": "biome check src/ scripts/",
		"lint:fix": "biome check --write src/ scripts/ && biome format --write src/ scripts/",
		"format": "biome format --write .",
		"skills": "autoskills",
		"skills:check": "autoskills --dry-run",
		"optimize:images": "bun run scripts/optimize-images.mjs",
		"generate:og": "bun run scripts/generate-og-image.ts",
		"sync:aosp": "bun run scripts/sync-aosp-devices.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.21.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@typescript/native-preview": "^7.0.0-dev.20260617.2",
		"autoskills": "^0.3.6",
		"bits-ui": "^2.16.3",
		"cookie": "^0.7.0",
		"sharp": "^0.35.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@fontsource/geist-mono": "^5.2.8",
		"@fontsource/geist-sans": "^5.2.5",
		"animejs": "^4.4.1",
		"clsx": "^2.1.1",
		"fuse.js": "^7.4.2",
		"phosphor-svelte": "^3.1.0",
		"tailwind-merge": "^3.6.0"
	},
	"overrides": {
		"cookie": "^0.7.0"
	}
}
