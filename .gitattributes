# Force LF line endings on text files. Windows + git auto-converts to
# CRLF on checkout (core.autocrlf=true), which is what causes the
# "LF will be replaced by CRLF" warning on every commit. This file
# makes git store and serve everything as LF, regardless of platform.
* text=auto eol=lf

# Shell scripts and makefiles must stay executable on Linux/macOS.
*.sh text eol=lf
*.bash text eol=lf
Makefile text eol=lf

# Windows scripts that need CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Generated by sharp on prebuild. Binary content; no line-ending magic.
*.avif binary
*.webp binary

# True binary (images, fonts, archives).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
