# ===== seba3567.cl — frontend env (dev) =====
#
# Bun expone solo las variables prefijadas con PUBLIC_ al bundle del
# cliente. Las que NO tienen prefijo PUBLIC_ son solo para procesos
# del server / build (no se envían al browser).
#
# Copiá este archivo a .env y editá los valores. .env está en
# .gitignore, así que podés meter claves privadas sin miedo.

# ---- API del backend (formulario de contacto) ----
# El endpoint /api/contact es público y está rate-limited por IP.
# En dev apunta al Go local; en prod a la API de la intranet.
PUBLIC_API_URL=http://localhost:3000

# ---- AOSP device catalog (server-side sync) ----
# El script `bun run sync:aosp` descarga el YAML de devices desde
# esta URL al build y lo guarda en src/lib/data/aosp/devices.json
# como fallback para SSR. El cliente también lo trae en runtime,
# así que correr este script es opcional.
#
# Si está vacía o falta, usa el default
# (seba3567/devices-json en main).
#
# Ejemplos:
#   AOSP_DEVICES_YAML_URL=https://raw.githubusercontent.com/seba3567/devices-json/main/devices.yaml
#   AOSP_DEVICES_YAML_URL=https://gitlab.com/seba3567/devices/-/raw/main/devices.yaml
AOSP_DEVICES_YAML_URL=

# ---- AOSP status filter (server-side sync) ----
# CSV de statuses a incluir en la grilla. Por defecto ocultamos
# 'paused', 'abandoned' y 'eol' para que /aosp muestre solo los
# build targets en desarrollo activo. Si querés incluir pausados
# o deprecados, seteá:
#   AOSP_DEVICES_INCLUDE_STATUSES=active,beta,paused,abandoned,eol
# Los devices filtrados se guardan en devices.json bajo
# `discontinued` (para referencia, no se renderizan en la página).
AOSP_DEVICES_INCLUDE_STATUSES=active,beta

# ---- AOSP client-side fetch (PUBLIC — se envía al browser) ----
# La página /aosp también fetcha el YAML directo desde el browser
# (con SWR de 15 min en localStorage). Si querés apuntar a otro
# repositorio / branch en runtime, sobreescribí esta variable.
# Si está vacía, usa el default
# (raw.githubusercontent.com/seba3567/devices-json/main/devices.yaml).
#
# NO la uses con un token / credencial — esta URL queda visible
# en el bundle del cliente.
PUBLIC_AOSP_DEVICES_YAML_URL=

# CSV de statuses que el cliente acepta. Default: active,beta.
# Cualquier status fuera de este set se guarda en `discontinued`
# en el snapshot y se ignora en la UI.
PUBLIC_AOSP_DEVICES_INCLUDE_STATUSES=active,beta
